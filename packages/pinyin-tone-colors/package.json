{
  "name": "pinyin-tone-colors",
  "version": "0.1.0",
  "description": "Color Mandarin pinyin and hanzi by tone. Zero-dependency, framework-agnostic core with an optional React component.",
  "keywords": [
    "pinyin",
    "mandarin",
    "chinese",
    "tone",
    "tones",
    "tone-colors",
    "hanzi",
    "hsk",
    "react",
    "language-learning"
  ],
  "license": "MIT",
  "author": "Codingqueen40",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codingqueen40/chinese.io.git",
    "directory": "packages/pinyin-tone-colors"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "adaptive-placement",
  "version": "0.1.0",
  "description": "A tiny, dependency-free staircase adaptive placement-test engine. Pure, immutable, domain-agnostic logic.",
  "keywords": [
    "placement",
    "adaptive",
    "adaptive-testing",
    "staircase",
    "level-test",
    "assessment",
    "quiz",
    "cat",
    "education",
    "language-learning"
  ],
  "license": "MIT",
  "author": "Codingqueen40",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codingqueen40/chinese.io.git",
    "directory": "packages/adaptive-placement"
  },
  "publishConfig": {
    "access": "public"
  }
}
